__pycache__/
*.py[cod]
.DS_Store
.pytest_cache/
.venv/
venv/

# Bundled MAVSDK Server (run `make` or ./scripts/fetch_mavsdk_server.sh)
Sources/GuardianHQ/Resources/mavsdk_server

# ArduPilot upstream tree (run ./scripts/fetch_ardupilot_sitl.sh or make sitl-runtime).
# Keep the tracked marker file only.
Sources/GuardianHQ/Resources/ArduPilotSitl/*
!Sources/GuardianHQ/Resources/ArduPilotSitl/_GUARDIAN_DO_NOT_DELETE.txt

# PX4 SITL runtime (bin/px4 + etc/ — run ./scripts/sync_px4_sitl_bundle.sh or make px4-sitl-runtime).
Sources/GuardianHQ/Resources/Px4SitlBundle/*
!Sources/GuardianHQ/Resources/Px4SitlBundle/_GUARDIAN_DO_NOT_DELETE.txt

# ROS 2 autonomy upstream (Nav2, Aerostack2, as2_platform_pixhawk — make ros2-autonomy-stacks-fetch).
Sources/GuardianHQ/Resources/Ros2AutonomyStacks/upstream/*
!Sources/GuardianHQ/Resources/Ros2AutonomyStacks/upstream/_GUARDIAN_DO_NOT_DELETE.txt
Sources/GuardianHQ/Resources/Ros2AutonomyStacks/.guardian_ros2_autonomy_lock

# Gazebo Harmonic runtime (make gazebo-runtime).
Sources/GuardianHQ/Resources/GazeboRuntime/bin/*
!Sources/GuardianHQ/Resources/GazeboRuntime/bin/.gitkeep
Sources/GuardianHQ/Resources/GazeboRuntime/lib/*
!Sources/GuardianHQ/Resources/GazeboRuntime/lib/.gitkeep
Sources/GuardianHQ/Resources/GazeboRuntime/share/*
!Sources/GuardianHQ/Resources/GazeboRuntime/share/.gitkeep
Sources/GuardianHQ/Resources/GazeboRuntime/.guardian_gazebo_runtime_built
Sources/GuardianHQ/Resources/GazeboRuntime/.guardian_gz_sim_version
Sources/GuardianHQ/Resources/GazeboRuntime/.guardian_gz_source_rev

# GazeboWeb viewer bundle (make gzweb-viewer) — track dist/ + HTML only.
Sources/GuardianHQ/Resources/GazeboWeb/.build/

# ROS 2 merged runtime (install/ + MicroXRCEAgent — make ros2-runtime).
Sources/GuardianHQ/Resources/Ros2Runtime/overlay/
Sources/GuardianHQ/Resources/Ros2Runtime/install/setup.bash
Sources/GuardianHQ/Resources/Ros2Runtime/.guardian_ros2_runtime_built
Sources/GuardianHQ/Resources/Ros2Runtime/.guardian_ros2_runtime_built.meta
build/ros2_runtime_ws/
build/guardian_ros2_vehicle_bridge/
build/px4_msgs/
build/.built_by
build/COLCON_IGNORE
build/gz-fetch-debug.log
log/
Sources/GuardianHQ/Resources/Ros2Runtime/bin/*
!Sources/GuardianHQ/Resources/Ros2Runtime/bin/.gitkeep
Sources/GuardianHQ/Resources/Ros2Runtime/lib/*
!Sources/GuardianHQ/Resources/Ros2Runtime/lib/.gitkeep

# Swift / Xcode / SPM artifacts
.build/
.swiftpm/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# Stack wiki — dev-only autopilot doc index (not bundled into GuardianHQ).
Resources/StackWiki/upstream/
Resources/StackWiki/source/
Resources/StackWiki/index/chunks.jsonl.gz

# Local ROS 2 system prefix marker + RoboStack install (make ros2-system-install)
.guardian/

# Local scratch scaffold folder (not part of app source)
GuardianMacApp/

# Packaged macOS .app output (run `./scripts/package-macos-app.sh`)
build/*.app/
build/*.app
